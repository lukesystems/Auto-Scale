# WARNING: Never commit real keys (especially SUPABASE_SERVICE_ROLE_KEY) to git!
# Doing so compromises the security of the application. If you have done so, rotate the keys immediately.

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# ===== Provider mode =====
AUTOSCALE_PROVIDER_MODE_DEFAULT=managed

# ===== AI Providers =====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Default provider/model used when none specified (local dev often uses mock)
AUTOSCALE_DEFAULT_PROVIDER=mock
AUTOSCALE_DEFAULT_MODEL=mock-default

# Server-side timeout for AI provider requests (ms)
AI_REQUEST_TIMEOUT_MS=45000

# Task-based OpenRouter model routing (Managed Mode)
AUTOSCALE_MODEL_AUTOBRIEF=
AUTOSCALE_MODEL_TRENDWATCH=
AUTOSCALE_MODEL_DISCOVERY_REASONING=
AUTOSCALE_MODEL_VIDEOTREND_REASONING=
AUTOSCALE_MODEL_HOOK_GENERATION=
AUTOSCALE_MODEL_STRATEGY_GENERATION=
AUTOSCALE_MODEL_CONTENT=
AUTOSCALE_MODEL_QUALITY_GATE=
AUTOSCALE_MODEL_COMPOUND=
AUTOSCALE_MODEL_DEFAULT=

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Social publishing =====
PUBLISHING_PROVIDER=postbridge

# ===== Billing — Lemon Squeezy =====
# Billing gating activates automatically once API key + store ID are set.
# Set BILLING_ENFORCED=0 to test with keys present but gating off.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Variant IDs from the LS dashboard (Products → variant → copy ID)
LEMONSQUEEZY_PLAN_VARIANT_LAUNCH=
LEMONSQUEEZY_PLAN_VARIANT_GROWTH=
LEMONSQUEEZY_PLAN_VARIANT_OPERATOR=
LEMONSQUEEZY_TOPUP_VARIANT_SMALL=
LEMONSQUEEZY_TOPUP_VARIANT_MEDIUM=
LEMONSQUEEZY_TOPUP_VARIANT_LARGE=
# BILLING_ENFORCED=0

# ===== Post Bridge (Managed Mode — requires $5/mo API add-on) =====
# https://www.post-bridge.com/dashboard/api-keys
POST_BRIDGE_API_KEY=
# Optional override (default: https://api.post-bridge.com/v1)
# POST_BRIDGE_API_URL=https://api.post-bridge.com/v1
# Required only for Advanced/BYOK mode. Use a long random server-side secret.
POSTBRIDGE_CREDENTIAL_ENCRYPTION_KEY=

# ===== Fal (media foundation — generation not active yet) =====
FAL_KEY=
AUTOSCALE_FAL_SEEDANCE_MODEL=bytedance/seedance-2.0/text-to-video
AUTOSCALE_FAL_SEEDANCE_I2V_MODEL=bytedance/seedance-2.0/image-to-video
AUTOSCALE_FAL_IMAGE_MODEL=fal-ai/flux-pro/v1.1-ultra
AUTOSCALE_FAL_IMAGE_FAST_MODEL=fal-ai/flux/schnell
AUTOSCALE_FAL_TTS_MODEL=fal-ai/minimax/speech-02-hd

# ===== Tracking webhooks =====
AUTOSCALE_WEBHOOK_SIGNING_KEY=

# ===== Cron / autopilot =====
AUTOSCALE_CRON_SECRET=

# ===== Stage 3 render worker =====
# Local/dev can drain render jobs in-process when cron is not configured.
AUTOSCALE_RENDER_WORKER_LOCAL=1
# Raise on machines with enough CPU/RAM. Fal provider limits may still dominate AI scenes.
AUTOSCALE_RENDER_CONCEPT_CONCURRENCY=4
AUTOSCALE_RENDER_WORKER_CLAIM_BATCH=16
AUTOSCALE_RENDER_LOCAL_DRAIN_BATCHES=4
# Stage 2 tail: scripts + storyboards per concept. Keep at 3 for first-loop batches.
AUTOSCALE_SCRIPT_STORYBOARD_CONCURRENCY=3

# ===== Post Bridge live smoke test (optional) =====
# POST_BRIDGE_SMOKE_TEST=1
# POST_BRIDGE_SMOKE_ACCOUNT_ID=
# POST_BRIDGE_SMOKE_VIDEO_URL=https://example.com/sample.mp4

# ===== Product Site Intelligence (Phase 1) =====
# Optional: self-hosted Crawl4AI HTTP endpoint for richer markdown extraction
CRAWL4AI_API_URL=

# ===== Voiceover (Phase 3 render) =====
# Primary TTS provider: elevenlabs | openai | silent
VOICE_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
# ElevenLabs voice ID (ELEVENLABS_VOICE_ID takes precedence over DEFAULT_VOICE_ID)
# Free tier: use premade voices only (Voice Library voices return HTTP 402 via API).
# Examples — Rachel: 21m00Tcm4TlvDq8ikWAM, Adam: pNInz6obpgDQGcFmaJgB, Sarah: EXAVITQu4vr4xnSDxMaL
# Leave unset to default to Rachel; library voice IDs require a paid ElevenLabs plan.
ELEVENLABS_VOICE_ID=
DEFAULT_VOICE_ID=
# Fallback when configured voice is missing or blocked on free tier (default: Rachel)
ELEVENLABS_FALLBACK_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# OpenAI TTS fallback (when ElevenLabs fails or VOICE_PROVIDER=openai)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# ===== FFmpeg (local render) =====
# Prefer explicit path on Windows; overrides ffmpeg-static when set
FFMPEG_PATH=

# ===== Growth media storage =====
# supabase (default) or r2. Use r2 for production rendered/raw media CDN.
GROWTH_MEDIA_STORAGE_PROVIDER=supabase
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=autoscale-growth-media
# Public custom domain or public bucket URL, no trailing slash.
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# ===== Cloud Run render worker =====
# Base URL of the Cloud Run render worker service, e.g. https://autoscale-render-worker-xyz.a.run.app
AUTOSCALE_RENDER_WORKER_URL=
# Shared secret for POST /run on the render worker service.
AUTOSCALE_RENDER_WORKER_SECRET=
AUTOSCALE_RENDER_WORKER_MAX_BATCHES=4

# ===== Competitor Discovery (Phase 2) =====
# Optional power mode — hosted Firecrawl (not Firebase)
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev
# Rescue adapter for interaction-heavy public pages only
BROWSER_USE_API_URL=

# ===== X (Twitter) Discovery — Apify =====
# https://apify.com — used for real engagement-metric X search (see docs/SCRAPING_ENGINE.md)
APIFY_API_TOKEN=
# Defaults to api-ninja/x-twitter-advanced-search; override to swap actors without a code change
APIFY_X_ACTOR_ID=
