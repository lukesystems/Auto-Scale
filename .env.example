# ===== Supabase =====
# Public URL and anon key are safe to expose only as frontend public values,
# but use placeholders in example files.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never commit a real service role key.
SUPABASE_SERVICE_ROLE_KEY=

# ===== AI Providers (set at least one) =====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Default provider/model used when none specified
AUTOSCALE_DEFAULT_PROVIDER=mock
AUTOSCALE_DEFAULT_MODEL=mock-default

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Postiz =====
# Optional fallback/env-level config. Prefer per-user encrypted storage later.
POSTIZ_API_URL=https://api.postiz.com/public/v1
POSTIZ_API_KEY=
